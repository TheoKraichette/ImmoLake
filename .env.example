# =====================================================================
# ImmoLake — variables d'environnement
# Copier ce fichier en `.env` puis ajuster si besoin :  cp .env.example .env
# =====================================================================

# --- Airflow ---
AIRFLOW_IMAGE_NAME=apache/airflow:3.1.8
# UID de l'utilisateur hôte (Linux/Mac : `id -u`). Sous Windows, laisser 50000.
AIRFLOW_UID=50000
# Identifiants de connexion à l'UI Airflow (http://localhost:8080)
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
# Dépendances Python ajoutées aux conteneurs Airflow au démarrage
_PIP_ADDITIONAL_REQUIREMENTS=apache-airflow-providers-amazon pandas pyarrow requests pytest duckdb

# --- Data Lake (MinIO) ---
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_password_2026
MINIO_BUCKET=immolake
MINIO_ENDPOINT=minio:9000

# --- Ingestion ADEME (par departement, streaming) ---
# Liste blanche des departements a ingerer (vide = aucun). Defaut = 28 departements :
#   12 metropoles : 75 Paris, 69 Lyon, 13 Marseille, 33 Bordeaux, 31 Toulouse, 06 Nice, 44 Nantes,
#                   76 Rouen, 34 Montpellier, 59 Lille, 35 Rennes, 38 Grenoble
#   + villes moyennes : 21 Dijon, 51 Reims, 63 Clermont, 49 Angers, 37 Tours, 14 Caen, 54 Nancy,
#                   30 Nimes, 64 Pau, 17 La Rochelle
#   + petits departements : 48 Lozere, 23 Creuse, 15 Cantal, 05 Htes-Alpes, 90 Belfort, 09 Ariege
# Ajouter des departements = plus de villes (ingestion ADDITIVE : ne re-ingere pas les autres).
# NB : DVF ne couvre pas l'Alsace-Moselle (67/68/57, livre foncier) -> ces dep n'auraient pas de prix.
ADEME_DEPARTEMENTS=75,69,13,33,31,06,44,76,34,59,35,38,21,51,63,49,37,14,54,30,64,17,48,23,15,05,90,09
ADEME_PAGE_SIZE=1000
# Flush du buffer en Parquet tous les N lignes (memoire bornee).
ADEME_FLUSH_ROWS=50000
# Plafonds : nb max de pages par departement (vide = tout, mais long sur 12 dep / plusieurs M DPE ;
# mettre p.ex. 20 pour un run de demo rapide), et parallelisation (LocalExecutor).
ADEME_MAX_PAGES=
ADEME_MAX_ACTIVE_TASKS=4

# --- Ingestion DVF (geo-dvf, par departement) ---
# Le DVF est telecharge automatiquement pour chaque departement ci-dessus (couverture alignee sur
# les DPE -> prix/m2 partout). Annee du millesime DVF :
DVF_YEAR=2024
# Optionnel : restreindre le DVF a d'autres departements que les DPE (defaut = ADEME_DEPARTEMENTS).
DVF_DEPARTEMENTS=
# Optionnel (override) : un unique CSV DVF (ex. une commune) au lieu de la couverture par departement.
# Exemple : https://files.data.gouv.fr/geo-dvf/latest/csv/2024/communes/44/44109.csv
DVF_CSV_URL=

# --- WhatsApp (bonus — alertes, via Twilio) ---
# Sandbox Twilio WhatsApp : renseigner pour activer les alertes
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
WHATSAPP_TO=
