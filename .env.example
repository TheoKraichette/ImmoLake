# =====================================================================
# ImmoLake — variables d'environnement
# Copier ce fichier en `.env` puis ajuster si besoin :  cp .env.example .env
# =====================================================================

# --- Airflow ---
AIRFLOW_IMAGE_NAME=apache/airflow:3.1.8
# UID de l'utilisateur hôte (Linux/Mac : `id -u`). Sous Windows, laisser 50000.
AIRFLOW_UID=50000
# Identifiants de connexion à l'UI Airflow (http://localhost:8080)
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
# Dépendances Python ajoutées aux conteneurs Airflow au démarrage
_PIP_ADDITIONAL_REQUIREMENTS=apache-airflow-providers-amazon apache-airflow-providers-postgres pandas pyarrow requests pytest

# --- Data Warehouse (PostgreSQL métier) ---
DWH_USER=dwh_user
DWH_PASSWORD=dwh_password
DWH_DB=immolake

# --- Data Lake (MinIO) ---
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_password_2026
MINIO_BUCKET=immolake

# --- Ingestion ADEME ---
# Optionnel : limiter l'extraction a une commune pendant le developpement.
ADEME_CODE_POSTAL=
ADEME_CODE_INSEE=
ADEME_PAGE_SIZE=1000
ADEME_MAX_PAGES=

# --- Ingestion DVF ---
# REQUISE pour lancer le DAG transform (sinon la tache dvf_to_raw echoue).
# Exemple par commune : https://files.data.gouv.fr/geo-dvf/latest/csv/2024/communes/44/44109.csv
DVF_CSV_URL=
# Optionnel : limiter le nombre de lignes DVF pendant le developpement.
DVF_MAX_ROWS=50000

# --- Metabase (provisioning par scripts/setup_metabase.py) ---
MB_ADMIN_EMAIL=admin@immolake.local
MB_ADMIN_PASSWORD=immolake_admin_2026

# --- WhatsApp (bonus — alertes, via Twilio) ---
# Sandbox Twilio WhatsApp : renseigner pour activer les alertes
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
WHATSAPP_TO=
