# =====================================================================
# ImmoLake — variables d'environnement
# Copier ce fichier en `.env` puis ajuster si besoin :  cp .env.example .env
# =====================================================================

# --- Airflow ---
AIRFLOW_IMAGE_NAME=apache/airflow:3.1.8
# UID de l'utilisateur hôte (Linux/Mac : `id -u`). Sous Windows, laisser 50000.
AIRFLOW_UID=50000
# Identifiants de connexion à l'UI Airflow (http://localhost:8080)
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
# Dépendances Python ajoutées aux conteneurs Airflow au démarrage
_PIP_ADDITIONAL_REQUIREMENTS=apache-airflow-providers-amazon requests

# --- Data Warehouse (PostgreSQL métier) ---
DWH_USER=dwh_user
DWH_PASSWORD=dwh_password
DWH_DB=immolake

# --- Data Lake (MinIO) ---
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_password_2026
MINIO_BUCKET=immolake

# --- Telegram (bonus — alertes) ---
# Créer un bot via @BotFather puis renseigner ici
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
